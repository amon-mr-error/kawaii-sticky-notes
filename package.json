{
  "name": "kawaii-sticky-notes",
  "version": "1.0.0",
  "description": "Cute pastel sticky notes desktop app, in the style of Windows Sticky Notes",
  "main": "main.js",
  "author": "Amon <kes.karna12@gmail.com>",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "electron . --no-sandbox",
    "dist": "electron-builder",
    "dist:linux": "electron-builder --linux",
    "dist:mac": "electron-builder --mac",
    "dist:appimage": "electron-builder --linux AppImage",
    "dist:deb": "electron-builder --linux deb"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "@fontsource/baloo-2": "^5.0.8",
    "@fontsource/nunito": "^5.0.17"
  },
  "build": {
    "appId": "com.kawaiinotes.app",
    "productName": "Kawaii Sticky Notes",
    "afterPack": "scripts/afterPack.js",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "assets/**/*",
      "node_modules/@fontsource/**/*",
      "package.json"
    ],
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Utility",
      "icon": "build/icon.png",
      "executableName": "kawaii-sticky-notes",
      "executableArgs": ["--no-sandbox"]
    },
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.utilities",
      "icon": "build/icon.png"
    }
  }
}
